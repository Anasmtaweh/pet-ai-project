# MongoDB Atlas Connection URI
# Get this from your MongoDB Atlas cluster settings
DB_URL=

# JWT Secret for authentication
# Generate a secure random string (minimum 32 characters)
JWT_SECRET=

# Email Service Credentials (Gmail or other SMTP provider)
# For Gmail: Use an App Password (2FA required), not your main password
EMAIL_USER=
EMAIL_PASS=

# OpenAI API Key (optional, required for AI Chat feature)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AWS S3 Configuration (optional, required for pet image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

